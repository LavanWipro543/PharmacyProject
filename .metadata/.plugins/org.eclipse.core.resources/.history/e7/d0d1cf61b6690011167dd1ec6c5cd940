package com.neobank.auth.service;

import com.neobank.auth.entity.User;
import com.neobank.auth.repository.UserRepository;
import com.neobank.auth.security.JwtUtil;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.security.crypto.password.PasswordEncoder;
import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;

import java.util.HashMap;
import java.util.Map;

@Service
public class AuthService {

    @Autowired
    private UserRepository repo;

    @Autowired
    private PasswordEncoder encoder;

    @Autowired
    private JwtUtil jwt;

    @Autowired
    private RestTemplate rest;

    public String register(User user) {

        user.setPassword(encoder.encode(user.getPassword()));

        if (user.getRole() == null || user.getRole().isBlank()) {
            user.setRole("CUSTOMER");
        }

        user.setRole(user.getRole().toUpperCase());

        User savedUser = repo.save(user);

        // ✅ Create bank account only for CUSTOMER
        // ✅ ADMIN will be saved only in users table, not accounts table
        if ("CUSTOMER".equalsIgnoreCase(savedUser.getRole())) {

            try {
                Map<String, Object> req = new HashMap<>();

                req.put("userId", savedUser.getId());
                req.put("email", savedUser.getEmail());
                req.put("name", savedUser.getName());

                rest.postForObject(
                        "http://ACCOUNT-SERVICE/accounts/create-from-user",
                        req,
                        Object.class
                );

            } catch (Exception e) {
                System.out.println("Account creation failed: " + e.getMessage());
            }
        }

        return "Registered successfully";
    }

    public String login(String email, String password) {

        User user = repo.findByEmail(email)
                .orElseThrow(() -> new RuntimeException("User not found"));

        if (!encoder.matches(password, user.getPassword())) {
            throw new RuntimeException("Invalid credentials");
        }

        return jwt.generateToken(user);
    }
}