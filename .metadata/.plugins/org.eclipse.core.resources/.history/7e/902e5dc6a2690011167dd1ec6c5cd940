package com.neobank.transaction.service;
import java.util.List;
import com.neobank.transaction.entity.Transaction;
import com.neobank.transaction.repository.TransactionRepository;

import jakarta.servlet.http.HttpServletRequest;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpEntity;
import org.springframework.http.HttpHeaders;
import org.springframework.http.HttpMethod;
import org.springframework.security.core.context.SecurityContextHolder;
import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;
import org.springframework.web.context.request.RequestContextHolder;
import org.springframework.web.context.request.ServletRequestAttributes;

import java.time.LocalDateTime;

@Service
public class TransactionService {

    @Autowired
    private RestTemplate restTemplate;

    @Autowired
    private TransactionRepository repo;

    private final String ACCOUNT_URL = "http://ACCOUNT-SERVICE/accounts";

    public String deposit(String accountNumber, double amount) {

        String email = getLoggedInEmail();

        try {
            HttpEntity<String> entity = new HttpEntity<>(getAuthHeaders());

            restTemplate.exchange(
                    ACCOUNT_URL + "/credit/" + accountNumber + "/" + amount,
                    HttpMethod.PUT,
                    entity,
                    String.class
            );

            save("CREDIT", null, accountNumber, amount, "SUCCESS", email);

            return "✅ Deposit Successful";

        } catch (Exception e) {
            e.printStackTrace();

            save("CREDIT", null, accountNumber, amount, "FAILED", email);

            return "❌ Deposit Failed";
        }
    }

    public String withdraw(String accountNumber, double amount) {

        String email = getLoggedInEmail();

        try {
            HttpEntity<String> entity = new HttpEntity<>(getAuthHeaders());

            restTemplate.exchange(
                    ACCOUNT_URL + "/debit/" + accountNumber + "/" + amount,
                    HttpMethod.PUT,
                    entity,
                    String.class
            );

            save("DEBIT", accountNumber, null, amount, "SUCCESS", email);

            return "✅ Withdraw Successful";

        } catch (Exception e) {
            e.printStackTrace();

            save("DEBIT", accountNumber, null, amount, "FAILED", email);

            return "❌ Withdraw Failed";
        }
    }

    public String transfer(String fromAccount, String toAccount, double amount) {

        String email = getLoggedInEmail();

        try {
            HttpEntity<String> entity = new HttpEntity<>(getAuthHeaders());

            restTemplate.exchange(
                    ACCOUNT_URL + "/debit/" + fromAccount + "/" + amount,
                    HttpMethod.PUT,
                    entity,
                    String.class
            );

            try {
                restTemplate.exchange(
                        ACCOUNT_URL + "/credit/" + toAccount + "/" + amount,
                        HttpMethod.PUT,
                        entity,
                        String.class
                );

                save("TRANSFER", fromAccount, toAccount, amount, "SUCCESS", email);

                return "✅ Transfer Successful";

            } catch (Exception creditFail) {
                creditFail.printStackTrace();

                restTemplate.exchange(
                        ACCOUNT_URL + "/credit/" + fromAccount + "/" + amount,
                        HttpMethod.PUT,
                        entity,
                        String.class
                );

                save("TRANSFER", fromAccount, toAccount, amount, "FAILED", email);

                return "❌ Transfer Failed. Rollback Done";
            }

        } catch (Exception e) {
            e.printStackTrace();

            save("TRANSFER", fromAccount, toAccount, amount, "FAILED", email);

            return "❌ Transfer Failed. Debit Issue";
        }
    }

    private HttpHeaders getAuthHeaders() {

        HttpHeaders headers = new HttpHeaders();

        ServletRequestAttributes attributes =
                (ServletRequestAttributes) RequestContextHolder.getRequestAttributes();

        if (attributes != null) {
            HttpServletRequest request = attributes.getRequest();

            String authHeader = request.getHeader("Authorization");

            if (authHeader != null && authHeader.startsWith("Bearer ")) {
                headers.set("Authorization", authHeader);
            }
        }

        return headers;
    }

    private String getLoggedInEmail() {
        return SecurityContextHolder
                .getContext()
                .getAuthentication()
                .getName();
    }

    private void save(String type, String from, String to, double amount, String status, String email) {

        Transaction transaction = new Transaction();

        transaction.setType(type);
        transaction.setFromAccount(from);
        transaction.setToAccount(to);
        transaction.setAmount(amount);
        transaction.setStatus(status);
        transaction.setEmail(email);
        transaction.setTimestamp(LocalDateTime.now());

        repo.save(transaction);
    }
    public List<Transaction> getMyTransactions() {

        String email = getLoggedInEmail();

        return repo.findByEmailOrderByTimestampDesc(email);
    }
}