package com.pharmacy.apigateway.filter;

import java.nio.charset.StandardCharsets;

import org.springframework.cloud.gateway.filter.GatewayFilterChain;
import org.springframework.cloud.gateway.filter.GlobalFilter;
import org.springframework.core.Ordered;
import org.springframework.http.HttpStatus;
import org.springframework.http.server.reactive.ServerHttpRequest;
import org.springframework.stereotype.Component;
import org.springframework.web.server.ServerWebExchange;

import com.pharmacy.apigateway.util.JwtUtil;

import reactor.core.publisher.Mono;

@Component
public class JwtAuthenticationFilter implements GlobalFilter, Ordered {

    private final JwtUtil jwtUtil;

    public JwtAuthenticationFilter(JwtUtil jwtUtil) {
        this.jwtUtil = jwtUtil;
    }

    @Override
    public Mono<Void> filter(ServerWebExchange exchange, GatewayFilterChain chain) {

        ServerHttpRequest request = exchange.getRequest();

        String path = request.getURI().getPath();
        String method = request.getMethod().name();

        if (isPublicEndpoint(path)) {
            return chain.filter(exchange);
        }

        String authHeader = request.getHeaders().getFirst("Authorization");

        if (authHeader == null || !authHeader.startsWith("Bearer ")) {
            return unauthorized(exchange, "Missing or invalid Authorization header");
        }

        String token = authHeader.substring(7);

        if (!jwtUtil.isTokenValid(token)) {
            return unauthorized(exchange, "Invalid or expired JWT token");
        }

        String role = jwtUtil.extractRole(token);
        String email = jwtUtil.extractEmail(token);

        if (!isAuthorized(path, role, method)) {
            return forbidden(exchange, "Access denied for role: " + role);
        }

        ServerHttpRequest modifiedRequest = request.mutate()
                .header("X-User-Email", email)
                .header("X-User-Role", role)
                .build();

        return chain.filter(exchange.mutate().request(modifiedRequest).build());
    }

    private boolean isPublicEndpoint(String path) {
        return path.contains("/auth-service/auth/register")
                || path.contains("/auth-service/auth/login")
                || path.contains("/auth-service/auth/test")
                || path.contains("/AUTH-SERVICE/auth/register")
                || path.contains("/AUTH-SERVICE/auth/login")
                || path.contains("/AUTH-SERVICE/auth/test")
                || path.contains("/actuator")
                || path.contains("/swagger-ui")
                || path.contains("/swagger-ui.html")
                || path.contains("/v3/api-docs")
                || path.contains("/webjars")
                || path.contains("/swagger-resources");
    }

    private boolean isAuthorized(String path, String role, String method) {

        if (role == null) {
            return false;
        }

        String normalizedRole = role.replace("ROLE_", "").trim().toUpperCase();

        if ("ADMIN".equals(normalizedRole)) {
            return true;
        }

        if ("CUSTOMER".equals(normalizedRole)) {
            return isCustomerAllowed(path, method);
        }

        if ("PHARMACIST".equals(normalizedRole)) {
            return isPharmacistAllowed(path, method);
        }

        return false;
    }

    private boolean isCustomerAllowed(String path, String method) {

        if (isMedicinePath(path) && "GET".equals(method)) {
            return true;
        }

        if (isCartPath(path)) {
            return true;
        }

        if (isOrderPath(path)) {
            return true;
        }

        if (isPrescriptionPath(path)) {
            return true;
        }

        if (isNotificationPath(path) && "GET".equals(method)) {
            return true;
        }

        return false;
    }

    private boolean isPharmacistAllowed(String path, String method) {

        if (isMedicinePath(path) && "GET".equals(method)) {
            return true;
        }


        if (isPrescriptionPath(path)) {
            return true;
        }

        return false;
    }

    private boolean isMedicinePath(String path) {
        return path.contains("/medicine-service/medicines")
                || path.contains("/MEDICINE-SERVICE/medicines");
    }

    private boolean isCartPath(String path) {
        return path.contains("/cart-service/cart")
                || path.contains("/CART-SERVICE/cart");
    }

    private boolean isOrderPath(String path) {
        return path.contains("/order-service/orders")
                || path.contains("/ORDER-SERVICE/orders");
    }

    private boolean isPrescriptionPath(String path) {
        return path.contains("/prescription-service/prescriptions")
                || path.contains("/PRESCRIPTION-SERVICE/prescriptions");
    }

    private boolean isInventoryPath(String path) {
        return path.contains("/inventory-service/inventory")
                || path.contains("/INVENTORY-SERVICE/inventory");
    }

    private boolean isNotificationPath(String path) {
        return path.contains("/notification-service/notifications")
                || path.contains("/NOTIFICATION-SERVICE/notifications");
    }

    private Mono<Void> unauthorized(ServerWebExchange exchange, String message) {

        exchange.getResponse().setStatusCode(HttpStatus.UNAUTHORIZED);

        byte[] bytes = message.getBytes(StandardCharsets.UTF_8);

        return exchange.getResponse()
                .writeWith(Mono.just(exchange.getResponse()
                        .bufferFactory()
                        .wrap(bytes)));
    }

    private Mono<Void> forbidden(ServerWebExchange exchange, String message) {

        exchange.getResponse().setStatusCode(HttpStatus.FORBIDDEN);

        byte[] bytes = message.getBytes(StandardCharsets.UTF_8);

        return exchange.getResponse()
                .writeWith(Mono.just(exchange.getResponse()
                        .bufferFactory()
                        .wrap(bytes)));
    }

    @Override
    public int getOrder() {
        return -1;
    }
}