package com.neobank.auth.security;

import io.jsonwebtoken.Jwts;
import io.jsonwebtoken.security.Keys;
import org.springframework.stereotype.Component;

import java.security.Key;
import java.util.Date;

@Component
public class JwtUtil {

    // ✅ Secret key (MUST be at least 32 characters)
    private final String SECRET = "neobank-secret-neobank-secret-123456";

    // ✅ Generate Key object
    private Key getSignKey() {
        return Keys.hmacShaKeyFor(SECRET.getBytes());
    }

    // ✅ Generate JWT Token
    public String generateToken(String email) {
        return Jwts.builder()
                .subject(email)   // ✅ NEW (instead of setSubject)
                .issuedAt(new Date())
                .expiration(new Date(System.currentTimeMillis() + 1000 * 60 * 60)) // 1 hour
                .signWith(getSignKey())  // ✅ NEW METHOD
                .compact();
    }

    // ✅ Extract Email from Token
    public String extractEmail(String token) {
        return Jwts.parser()
                .verifyWith(getSignKey())   // ✅ NEW (instead of setSigningKey)
                .build()
                .parseSignedClaims(token)
                .getPayload()
                .getSubject();
    }
}
