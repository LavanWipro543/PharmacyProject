package com.neobank.transaction.controller;

import com.neobank.transaction.dto.StatementDTO;
import com.neobank.transaction.entity.Transaction;
import com.neobank.transaction.service.TransactionService;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import org.springframework.security.core.context.SecurityContextHolder;

import java.util.*;

@RestController
@RequestMapping("/transactions")
@CrossOrigin
public class TransactionController {

    @Autowired
    private TransactionService service;

    // ✅ SAFE ROLE EXTRACTOR (VERY IMPORTANT FIX 🔥)
    private String getRole() {
        return SecurityContextHolder.getContext()
                .getAuthentication()
                .getAuthorities()
                .stream()
                .findFirst()
                .map(a -> a.getAuthority())
                .orElse("UNKNOWN");
        
    }

    // ✅ DEPOSIT
    @PostMapping("/deposit")
    public Object deposit(@RequestBody Map<String, Object> data) {

        String role = getRole();
        if (!role.equals("CUSTOMER")) {
            return "Access Denied: Customer only";
        }

        String acc = (String) data.get("accountNumber");
        double amount = ((Number) data.get("amount")).doubleValue();

        return service.deposit(acc, amount);
    }

    // ✅ WITHDRAW
    @PostMapping("/withdraw")
    public Object withdraw(@RequestBody Map<String, Object> data) {

        String role = getRole();
        if (!role.equals("CUSTOMER")) {
            return "Access Denied: Customer only";
        }

        String acc = (String) data.get("accountNumber");
        double amount = ((Number) data.get("amount")).doubleValue();

        return service.withdraw(acc, amount);
    }

    // ✅ TRANSFER USING BENEFICIARY 🔥
    @PostMapping("/transfer-beneficiary")
    public Object transferBeneficiary(@RequestBody Map<String, Object> data) {

        String role = getRole();
        if (!role.equals("CUSTOMER")) {
            return "Access Denied: Customer only";
        }

        String from = (String) data.get("fromAccount");
        Long beneficiaryId = Long.valueOf(data.get("beneficiaryId").toString());
        double amount = Double.parseDouble(data.get("amount").toString());

        return service.transferUsingBeneficiary(from, beneficiaryId, amount);
    }

    // ✅ MINI STATEMENT
    @GetMapping("/mini/{accountNumber}")
    public Object miniStatement(@PathVariable String accountNumber) {

        String role = getRole();
        if (!role.equals("CUSTOMER")) {
            return "Access Denied: Customer only";
        }

        List<Transaction> list = service.getMiniStatement(accountNumber);

        Map<String, Object> response = new HashMap<>();
        response.put("accountNumber", accountNumber);
        response.put("count", list.size());
        response.put("transactions", list);

        return response;
    }

    // ✅ FULL STATEMENT
    @GetMapping("/statement-detailed/{accountNumber}")
    public Object fullStatement(@PathVariable String accountNumber) {

        String role = getRole();
        if (!role.equals("CUSTOMER")) {
            return "Access Denied: Customer only";
        }

        return service.getFullStatement(accountNumber);
    }

    // ✅ ALL TRANSACTIONS
    @GetMapping("/{accountNumber}")
    public Object getTransactions(@PathVariable String accountNumber) {

        String role = getRole();
        if (!role.equals("CUSTOMER")) {
            return "Access Denied: Customer only";
        }

        return service.getTransactions(accountNumber);
    }
}