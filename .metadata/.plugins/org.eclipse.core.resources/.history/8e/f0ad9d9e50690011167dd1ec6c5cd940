spring.application.name=neo-bank-api-gateway
server.port=8080


eureka.client.service-url.defaultZone=http://localhost:8761/eureka/

# ROUTING

spring.cloud.gateway.routes[0].id=auth-service
spring.cloud.gateway.routes[0].uri=lb://NEO-BANK-AUTH-SERVICE
spring.cloud.gateway.routes[0].predicates[0]=Path=/auth/**

spring.cloud.gateway.routes[1].id=account-service
spring.cloud.gateway.routes[1].uri=lb://NEO-BANK-ACCOUNT-SERVICE
spring.cloud.gateway.routes[1].predicates[0]=Path=/accounts/**

spring.cloud.gateway.routes[2].id=transaction-service
spring.cloud.gateway.routes[2].uri=lb://NEO-BANK-TRANSACTION-SERVICE
spring.cloud.gateway.routes[2].predicates[0]=Path=/transactions/**

spring.cloud.gateway.routes[3].id=beneficiary-service
spring.cloud.gateway.routes[3].uri=lb://NEO-BANK-BENEFICIARY-SERVICE
spring.cloud.gateway.routes[3].predicates[0]=Path=/beneficiaries/**

spring.cloud.gateway.routes[4].id=admin-service
spring.cloud.gateway.routes[4].uri=lb://NEO-BANK-ADMIN-SERVICE
spring.cloud.gateway.routes[4].predicates[0]=Path=/admin/**