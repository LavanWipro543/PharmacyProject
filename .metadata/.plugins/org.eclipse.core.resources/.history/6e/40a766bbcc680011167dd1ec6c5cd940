package com.neobank.transaction.service;

import com.neobank.transaction.dto.StatementDTO;
import com.neobank.transaction.entity.Transaction;
import com.neobank.transaction.repository.TransactionRepository;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;
import org.springframework.web.client.HttpClientErrorException;

import org.springframework.security.core.context.SecurityContextHolder;

import java.time.LocalDateTime;
import java.util.*;

@Service
public class TransactionService {

    @Autowired
    private RestTemplate restTemplate;

    @Autowired
    private TransactionRepository repo;

    private static final double WITHDRAW_LIMIT = 10000;
    private static final double DAILY_TRANSFER_LIMIT = 50000;

    // ✅ GET LOGGED-IN USER (SAFE)
    private String getLoggedInUser() {
        if (SecurityContextHolder.getContext().getAuthentication() == null) {
            return null;
        }
        return SecurityContextHolder.getContext()
                .getAuthentication()
                .getName();
    }

    // ✅ CHECK ACCOUNT OWNERSHIP
    private boolean isOwner(String accountNumber) {
        try {
            String loggedIn = getLoggedInUser();
            if (loggedIn == null) return false;

            Map<String, Object> account = restTemplate.getForObject(
                    "http://ACCOUNT-SERVICE/accounts/" + accountNumber,
                    Map.class
            );

            if (account == null) return false;

            String accountEmail = (String) account.get("email");

            return loggedIn.equals(accountEmail);

        } catch (Exception e) {
            return false;
        }
    }

    // ✅ DEPOSIT
    public String deposit(String accountNumber, double amount) {

        if (!isOwner(accountNumber)) {
            return "Access Denied: Not your account";
        }

        try {
            restTemplate.put(
                    "http://ACCOUNT-SERVICE/accounts/credit/" + accountNumber + "/" + amount,
                    null
            );
        } catch (HttpClientErrorException e) {
            return "Deposit Failed";
        }

        save("CREDIT", null, accountNumber, amount);
        return "Deposit Successful";
    }

    // ✅ WITHDRAW
    public String withdraw(String accountNumber, double amount) {

        if (!isOwner(accountNumber)) {
            return "Access Denied: Not your account";
        }

        if (amount > WITHDRAW_LIMIT) {
            return "Withdraw limit exceeded!";
        }

        try {
            restTemplate.put(
                    "http://ACCOUNT-SERVICE/accounts/debit/" + accountNumber + "/" + amount,
                    null
            );
        } catch (HttpClientErrorException e) {
            return "Withdraw Failed: Insufficient balance";
        }

        save("DEBIT", accountNumber, null, amount);
        return "Withdraw Successful";
    }

    // ✅ TRANSFER DIRECT
    public String transfer(String from, String to, double amount) {

        if (!isOwner(from)) {
            return "Access Denied: Not your account";
        }

        try {

            restTemplate.put(
                    "http://ACCOUNT-SERVICE/accounts/debit/" + from + "/" + amount,
                    null
            );

            restTemplate.put(
                    "http://ACCOUNT-SERVICE/accounts/credit/" + to + "/" + amount,
                    null
            );

            save("TRANSFER", from, to, amount);

            return "Transfer Successful";

        } catch (HttpClientErrorException e) {
            return "Transfer Failed: Insufficient balance";
        }
    }

    // ✅ SAVE TRANSACTION
    private void save(String type, String from, String to, double amount) {
        Transaction t = new Transaction();
        t.setType(type);
        t.setFromAccount(from);
        t.setToAccount(to);
        t.setAmount(amount);
        t.setTimestamp(LocalDateTime.now());
        repo.save(t);
    }

    // ✅ DAILY LIMIT CALCULATION
    private double getTodayTransferTotal(String acc) {

        List<Transaction> list = repo.findByFromAccount(acc);
        LocalDateTime todayStart = LocalDateTime.now().toLocalDate().atStartOfDay();

        return list.stream()
                .filter(t -> "TRANSFER".equals(t.getType()))
                .filter(t -> t.getTimestamp().isAfter(todayStart))
                .mapToDouble(Transaction::getAmount)
                .sum();
    }

    // ✅ TRANSFER USING BENEFICIARY
    public String transferUsingBeneficiary(String fromAccount, Long beneficiaryId, double amount) {

        if (!isOwner(fromAccount)) {
            return "Access Denied: Not your account";
        }

        try {

            double today = getTodayTransferTotal(fromAccount);
            if (today + amount > DAILY_TRANSFER_LIMIT) {
                return "Daily transfer limit exceeded!";
            }

            Map<String, Object> beneficiary = restTemplate.getForObject(
                    "http://BENEFICIARY-SERVICE/beneficiaries/details/" + beneficiaryId,
                    Map.class
            );

            if (beneficiary == null) {
                return "Beneficiary not found";
            }

            String toAccount = (String) beneficiary.get("accountNumber");

            restTemplate.put(
                    "http://ACCOUNT-SERVICE/accounts/debit/" + fromAccount + "/" + amount,
                    null
            );

            restTemplate.put(
                    "http://ACCOUNT-SERVICE/accounts/credit/" + toAccount + "/" + amount,
                    null
            );

            save("TRANSFER", fromAccount, toAccount, amount);

            return "Transfer Successful";

        } catch (HttpClientErrorException e) {
            return "Transfer Failed: Insufficient balance";
        }
    }

    // ✅ MINI STATEMENT
    public List<Transaction> getMiniStatement(String acc) {

        if (!isOwner(acc)) {
            return new ArrayList<>();
        }

        List<Transaction> list = getTransactions(acc);
        list.sort((a, b) -> b.getTimestamp().compareTo(a.getTimestamp()));

        return list.stream().limit(5).toList();
    }

    // ✅ FULL STATEMENT
    public List<StatementDTO> getFullStatement(String accountNumber) {

        if (!isOwner(accountNumber)) {
            return new ArrayList<>();
        }

        List<Transaction> list = getTransactions(accountNumber);
        list.sort(Comparator.comparing(Transaction::getTimestamp));

        List<StatementDTO> result = new ArrayList<>();
        double balance = 0;

        for (Transaction t : list) {

            if ("CREDIT".equals(t.getType()) || accountNumber.equals(t.getToAccount())) {
                balance += t.getAmount();
            } else {
                balance -= t.getAmount();
            }

            StatementDTO dto = new StatementDTO();
            dto.setDate(t.getTimestamp().toLocalDate().toString());
            dto.setAmount(t.getAmount());
            dto.setType(t.getType());
            dto.setBalanceAfter(balance);

            if ("TRANSFER".equals(t.getType())) {
                dto.setDescription("Transfer to " + t.getToAccount());
            } else if ("CREDIT".equals(t.getType())) {
                dto.setDescription("Credit");
            } else {
                dto.setDescription("Debit");
            }

            result.add(dto);
        }

        return result;
    }

    // ✅ ALL TRANSACTIONS
    public List<Transaction> getTransactions(String acc) {

        if (!isOwner(acc)) {
            return new ArrayList<>();
        }

        List<Transaction> sent = repo.findByFromAccount(acc);
        List<Transaction> received = repo.findByToAccount(acc);

        sent.addAll(received);
        return sent;
    }
}