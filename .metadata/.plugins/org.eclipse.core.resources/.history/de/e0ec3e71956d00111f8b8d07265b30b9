server.port=8080

spring.application.name=API-GATEWAY

spring.config.import=optional:configserver:http://localhost:8888
spring.cloud.config.import-check.enabled=false

eureka.client.service-url.defaultZone=http://localhost:8761/eureka/
eureka.client.register-with-eureka=true
eureka.client.fetch-registry=true

spring.cloud.gateway.discovery.locator.enabled=true
spring.cloud.gateway.discovery.locator.lower-case-service-id=true

management.endpoints.web.exposure.include=*
management.endpoint.health.show-details=always

springdoc.api-docs.enabled=true
springdoc.swagger-ui.enabled=true
springdoc.swagger-ui.path=/swagger-ui.html
springdoc.swagger-ui.disable-swagger-default-url=true
springdoc.swagger-ui.config-url=/v3/api-docs/swagger-config

jwt.secret=ThisIsASecretKeyForOnlinePharmacyAuthServiceJwtTokenGeneration123456789
springdoc.api-docs.path=/v3/api-docs
springdoc.swagger-ui.urls[0].name=auth-service
springdoc.swagger-ui.urls[0].url=/auth-service/v3/api-docs

springdoc.swagger-ui.urls[1].name=medicine-service
springdoc.swagger-ui.urls[1].url=/medicine-service/v3/api-docs

springdoc.swagger-ui.urls[2].name=prescription-service
springdoc.swagger-ui.urls[2].url=/prescription-service/v3/api-docs

springdoc.swagger-ui.urls[3].name=inventory-service
springdoc.swagger-ui.urls[3].url=/inventory-service/v3/api-docs

springdoc.swagger-ui.urls[4].name=cart-service
springdoc.swagger-ui.urls[4].url=/cart-service/v3/api-docs

springdoc.swagger-ui.urls[5].name=notification-service
springdoc.swagger-ui.urls[5].url=/notification-service/v3/api-docs

springdoc.swagger-ui.urls[6].name=order-service
springdoc.swagger-ui.urls[6].url=/order-service/v3/api-docs